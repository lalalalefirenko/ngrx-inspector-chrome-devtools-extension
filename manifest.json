{
  "manifest_version": 3,
  "name": "NgRx Inspector",
  "version": "0.0.2",
  "devtools_page": "devtools.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icon_active_16.png",
    "32": "icon_active_32.png",
    "48": "icon_active_48.png",
    "128": "icon_active_128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon_16.png",
      "48": "icon_active_48.png"
    }
  },
  "permissions": ["storage"]
}
